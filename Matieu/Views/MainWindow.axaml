<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Matieu.MainWindow"
        Title="Матье"
        Width="800" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="WhiteSmoke"
        Icon="avares://Matieu/Resources/Logo.ico">

    <Border BorderBrush="Gray" BorderThickness="1">
        <Grid RowDefinitions="36,*">

            <Grid Grid.Row="0" Name="titleBar" ColumnDefinitions="*,Auto,Auto" Background="#4A90D9">
                <TextBlock Grid.Column="0" Text="Матье" Foreground="White"
                           VerticalAlignment="Center" Margin="10,0" FontSize="13"/>
                <Button Grid.Column="1" Name="minimizeBtn" Content="Свернуть"
                        Height="36" Padding="10,0" Background="Transparent"
                        Foreground="White" BorderThickness="0"/>
                <Button Grid.Column="2" Name="closeBtn" Content="Закрыть"
                        Height="36" Padding="10,0" Background="Transparent"
                        Foreground="White" BorderThickness="0"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="170,*,160">

                <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto,Auto" Background="#F0F0F0" >
                    <Border Grid.Row="0" Margin="12,12,12,8" BorderBrush="LightGray"
                            BorderThickness="1" Height="90">
                        <Image Name="logoImage" Stretch="Uniform" Margin="4"/>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="10,0,10,6">
                        <Button Name="servicesBtn" Content="Услуги"
                                HorizontalAlignment="Stretch" Height="32" Margin="0,0,0,4"/>
                        <Button Name="addServiceBtn" Content="Добавить услугу"
                                HorizontalAlignment="Stretch" Height="32" Margin="0,0,0,4"
                                IsVisible="False"/>
                    </StackPanel>

                    <Button Grid.Row="3" Name="logoutBtn" Content="Выход"
                            HorizontalAlignment="Stretch" Height="32" Margin="10,0,10,10"/>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="8,8,0,8">
                    <TabControl Grid.Row="0" Name="categoryTabs" Margin="0,0,0,4" Padding="0">
                        <TabItem Header="Кастом"/>
                        <TabItem Header="Косплей"/>
                    </TabControl>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Name="servicesPanel" Spacing="4"/>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Name="pageInfo"
                               VerticalAlignment="Center" Margin="0,4,0,0" FontSize="12"/>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,*" Margin="6,8,8,8">
                    <TextBox Grid.Row="0" Name="searchBox" Watermark="Поиск"
                             Height="30" Margin="0,0,0,4"/>
                    <ComboBox Grid.Row="1" Name="collectionFilter"
                              HorizontalAlignment="Stretch" Height="30" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                        <Button Name="prevBtn" Content="◄" Width="30" Height="30"/>
                        <Button Name="nextBtn" Content="►" Width="30" Height="30"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
