<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Matieu.ConfirmDialog"
        Width="320" Height="150"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Background="WhiteSmoke">

    <Border BorderBrush="Gray" BorderThickness="1">
        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Name="messageText" FontSize="14"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
            <Grid ColumnDefinitions="*,8,*">
                <Button Grid.Column="0" Name="yesBtn" Content="Да"
                        HorizontalAlignment="Stretch" Height="32"
                        Background="#4A90D9" Foreground="White" BorderThickness="0"/>
                <Button Grid.Column="2" Name="noBtn" Content="Нет"
                        HorizontalAlignment="Stretch" Height="32"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
